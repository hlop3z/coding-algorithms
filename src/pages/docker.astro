---
import DocsLayout from '@/layouts/DocsLayout.astro';
import NoteBox from '@/components/ui/NoteBox.astro';

interface CodeLine {
  caption?: string;
  command: string;
}

interface Section {
  icon: string;
  title: string;
  intro?: string;
  commands: CodeLine[];
  bullets?: string[];
  trailing?: string;
}

const sections: Section[] = [
  {
    icon: '🧹',
    title: 'Remove unused stuff (safe-ish default)',
    commands: [
      { command: 'docker system prune' },
    ],
    bullets: [
      'Removes stopped containers, unused networks, dangling images',
      'Does NOT remove volumes by default',
    ],
    trailing: 'To include volumes:',
  },
  {
    icon: '🗑️',
    title: 'Remove all unused images',
    commands: [
      { command: 'docker image prune -a' },
    ],
    bullets: ['Deletes all images not used by any container'],
  },
  {
    icon: '💾',
    title: 'Remove unused volumes',
    commands: [
      { command: 'docker volume prune' },
    ],
    bullets: ['Removes volumes not attached to any container'],
  },
  {
    icon: '💥',
    title: 'Remove EVERYTHING (aggressive cleanup)',
    commands: [
      { command: 'docker system prune -a --volumes' },
    ],
    intro: 'This will remove:',
    bullets: [
      'all stopped containers',
      'all unused images',
      'all unused networks',
      'all unused volumes',
    ],
    trailing: '👉 This is basically a full reset of unused Docker resources.',
  },
  {
    icon: '🎯',
    title: 'Remove specific items',
    commands: [
      { caption: 'Remove a specific image', command: 'docker rmi <image_id>' },
      { caption: 'Remove a specific volume', command: 'docker volume rm <volume_name>' },
    ],
  },
];

const inspectCommands = [
  'docker ps -a',
  'docker volume ls',
  'docker image ls',
];

let codeIndex = 0;
const nextId = () => `docker-code-${codeIndex++}`;
---

<DocsLayout title="Docker">
  <h1 class="text-3xl font-bold mb-2">Docker</h1>
  <p class="text-gray-600 dark:text-gray-400 mb-8">Docker Commands</p>

  <div class="space-y-8 max-w-3xl">
    {sections.map((section) => (
      <section class="border border-gray-200 dark:border-gray-700 rounded-lg p-5 bg-white dark:bg-gray-900">
        <h2 class="text-xl font-semibold mb-3 flex items-center gap-2">
          <span aria-hidden="true">{section.icon}</span>
          <span>{section.title}</span>
        </h2>

        {section.intro && (
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">{section.intro}</p>
        )}

        <div class="space-y-3">
          {section.commands.map((line) => {
            const id = nextId();
            return (
              <div>
                {line.caption && (
                  <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">{line.caption}</h3>
                )}
                <div class="relative group">
                  <code
                    id={id}
                    class="block bg-gray-100 dark:bg-gray-800 p-3 pr-12 rounded text-sm font-mono overflow-x-auto text-blue-700 dark:text-blue-300"
                  >
                    {line.command}
                  </code>
                  <button
                    type="button"
                    class="copy-btn absolute top-2 right-2 p-1.5 rounded bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 opacity-0 group-hover:opacity-100 focus:opacity-100 transition-opacity"
                    data-target={id}
                    aria-label="Copy to clipboard"
                  >
                    <svg class="w-4 h-4 text-gray-600 dark:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                  </button>
                </div>
              </div>
            );
          })}
        </div>

        {section.bullets && section.bullets.length > 0 && (
          <ul class="list-disc list-outside pl-5 mt-4 space-y-1 text-sm text-gray-600 dark:text-gray-400">
            {section.bullets.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        )}

        {section.trailing && (
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-3">{section.trailing}</p>
        )}
      </section>
    ))}

    <!-- Common pitfalls -->
    <NoteBox title="⚠️ Common pitfalls" variant="warning">
      <ul class="list-disc list-outside pl-5 space-y-1 text-sm">
        <li>Volumes often contain <strong>databases or persistent data</strong> → double-check before deleting</li>
        <li>If something won't delete, it's probably still attached to a container</li>
        <li>Use the inspection commands below to check first</li>
      </ul>

      <div class="space-y-2 mt-4">
        {inspectCommands.map((cmd) => {
          const id = nextId();
          return (
            <div class="relative group">
              <code
                id={id}
                class="block bg-gray-100 dark:bg-gray-800 p-2 pr-10 rounded text-sm font-mono overflow-x-auto text-blue-700 dark:text-blue-300"
              >
                {cmd}
              </code>
              <button
                type="button"
                class="copy-btn absolute top-1 right-1 p-1.5 rounded bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 opacity-0 group-hover:opacity-100 focus:opacity-100 transition-opacity"
                data-target={id}
                aria-label="Copy to clipboard"
              >
                <svg class="w-4 h-4 text-gray-600 dark:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
              </button>
            </div>
          );
        })}
      </div>
    </NoteBox>
  </div>
</DocsLayout>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const targetId = btn.getAttribute('data-target');
      const codeElement = document.getElementById(targetId!);
      const text = codeElement?.textContent?.trim() || '';

      try {
        await navigator.clipboard.writeText(text);

        const svg = btn.querySelector('svg');
        const originalPath = svg?.innerHTML;
        if (svg) {
          svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />';
          setTimeout(() => {
            svg.innerHTML = originalPath!;
          }, 1500);
        }
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    });
  });
</script>
